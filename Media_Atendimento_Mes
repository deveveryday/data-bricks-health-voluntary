--Média de atendimento por mês

SELECT 
    AVG(total_atendimentos) AS media_atendimentos_por_mes
FROM (

    SELECT 
        MONTH(data_atendimento) AS numero_mes,
        COUNT(*) AS total_atendimentos

    FROM dw_health_dashboard.dim_data_atendimento

    GROUP BY MONTH(data_atendimento)

) tabela;









